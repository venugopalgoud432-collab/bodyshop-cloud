<section class="stats-grid">
  <div class="stat-card">
    <div class="stat-label">Jobs</div>
    <div class="stat-value"><%= stats.totalJobs %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Open Jobs</div>
    <div class="stat-value"><%= stats.openJobs %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Waiting Parts</div>
    <div class="stat-value"><%= stats.waitingParts %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Hours Left</div>
    <div class="stat-value"><%= stats.hoursLeft.toFixed(1) %></div>
  </div>
</section>

<section class="card">
  <div class="section-head">
    <h1>Dashboard</h1>
    <div style="display:flex;gap:10px;flex-wrap:wrap;">
      <a href="/jobs/new" class="button">New Job</a>
      <a href="/timeclock" class="button secondary">Time Clock</a>
    </div>
  </div>

  <form method="get" action="/dashboard" class="form-grid" style="margin-bottom:16px;">
    <div>
      <label>Status Filter</label>
      <select name="status">
        <option value="">All</option>
        <% statusOptions.forEach(option => { %>
          <option value="<%= option.value %>" <%= filterStatus === option.value ? "selected" : "" %>>
            <%= option.label %>
          </option>
        <% }) %>
      </select>
    </div>

    <div>
      <label>Search</label>
      <input name="q" value="<%= q || '' %>" placeholder="RO, customer, make, model" />
    </div>

    <div style="display:flex;align-items:flex-end;">
      <button class="button">Apply Filters</button>
    </div>
  </form>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>RO</th>
          <th>Customer</th>
          <th>Vehicle</th>
          <th>Status</th>
          <th>Stage</th>
          <th>Hours</th>
          <th>Parts ETA</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (!jobs.length) { %>
          <tr>
            <td colspan="8" class="muted">No jobs found.</td>
          </tr>
        <% } %>

        <% jobs.forEach(job => { %>
          <tr>
            <td><strong><%= job.roNumber %></strong></td>
            <td><%= job.customerName %></td>
            <td><%= [job.year, job.make, job.model].filter(Boolean).join(" ") || "—" %></td>
            <td><%= statusLabel(job.status) %></td>
            <td><%= job.stage || "—" %></td>
            <td>
              <%= Number(job.hoursWorked || 0).toFixed(1) %> /
              <%= Number(job.estimatedHours || 0).toFixed(1) %>
              <br>
              <span class="muted"><%= hoursLeft(job).toFixed(1) %> left</span>
            </td>
            <td><%= job.partsEta ? new Date(job.partsEta).toLocaleDateString() : "—" %></td>
            <td>
              <div style="display:flex;gap:8px;flex-wrap:wrap;">
                <a href="/jobs/<%= job.id %>" class="button secondary small">Open</a>
                <a href="/status/<%= job.customerPortalToken %>" class="button secondary small">Customer</a>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
