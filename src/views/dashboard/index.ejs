<section class="dashboard-hero card">
  <div>
    <p class="eyebrow">Shop Performance</p>
    <h1>Welcome back, <%= currentUser.name.split(' ')[0] %></h1>
    <p class="hero-subtext">Track active repairs, due dates, and profitability from one clean dashboard.</p>
  </div>
  <div class="hero-actions mobile-stack">
    <a href="/jobs/new" class="button">+ New Job</a>
    <a href="/timeclock" class="button secondary">Time Clock</a>
    <a href="/production" class="button secondary">Production Board</a>
    <a href="/reports" class="button secondary">KPI Reports</a>
  </div>
</section>

<section class="stats-grid modern-grid">
  <div class="stat-card modern">
    <div class="stat-head">
      <div class="stat-label">Total Jobs</div>
      <span class="stat-chip">Open: <%= stats.openJobs %></span>
    </div>
    <div class="stat-value"><%= stats.totalJobs %></div>
  </div>

  <div class="stat-card modern">
    <div class="stat-head">
      <div class="stat-label">Waiting on Parts</div>
      <span class="stat-chip warning">Needs attention</span>
    </div>
    <div class="stat-value"><%= stats.waitingParts %></div>
  </div>

  <div class="stat-card modern">
    <div class="stat-head">
      <div class="stat-label">Ready To Deliver</div>
      <span class="stat-chip success">Close today</span>
    </div>
    <div class="stat-value"><%= stats.readyToDeliver %></div>
  </div>

  <div class="stat-card modern">
    <div class="stat-head">
      <div class="stat-label">Gross Profit</div>
      <span class="stat-chip">Month to date</span>
    </div>
    <div class="stat-value">$<%= stats.grossProfit.toFixed(0) %></div>
  </div>

  <div class="stat-card modern">
    <div class="stat-head">
      <div class="stat-label">Estimated Sales</div>
      <span class="stat-chip">Pipeline</span>
    </div>
    <div class="stat-value">$<%= stats.estimatedSales.toFixed(0) %></div>
  </div>

  <div class="stat-card modern">
    <div class="stat-head">
      <div class="stat-label">Average Cycle Days</div>
      <span class="stat-chip <%= stats.overdueJobs > 0 ? 'warning' : 'success' %>">
        <%= stats.overdueJobs %> overdue
      </span>
    </div>
    <div class="stat-value"><%= stats.avgCycleDays.toFixed(1) %></div>
  </div>

  <div class="stat-card modern compact">
    <div class="stat-label">Delivered This Month</div>
    <div class="stat-value"><%= stats.deliveredThisMonth %></div>
  </div>

  <div class="stat-card modern compact">
    <div class="stat-label">Active Techs</div>
    <div class="stat-value"><%= stats.activeTechs %> / <%= stats.clockedIn %> Clocked In</div>
  </div>

  <div class="stat-card modern compact">
    <div class="stat-label">Labour Potential</div>
    <div class="stat-value">$<%= stats.labourPotential.toFixed(0) %></div>
  </div>
</section>

<section class="card">
  <div class="section-head">
    <h2>Active Jobs</h2>
    <p class="muted">Filter jobs quickly and open repair orders in one tap.</p>
  </div>

  <form method="get" action="/dashboard" class="form-grid dashboard-filters">
    <div>
      <label>Status Filter</label>
      <select name="status">
        <option value="">All</option>
        <% statusOptions.forEach(option => { %>
          <option value="<%= option.value %>" <%= filterStatus === option.value ? "selected" : "" %>>
            <%= option.label %>
          </option>
        <% }) %>
      </select>
    </div>

    <div>
      <label>Search</label>
      <input name="q" value="<%= q || '' %>" placeholder="RO, customer, make, model, VIN, plate" />
    </div>

    <div style="display:flex;align-items:flex-end;">
      <button class="button">Apply Filters</button>
    </div>
  </form>

  <div class="table-wrap jobs-table-wrap">
    <table>
      <thead>
        <tr>
          <th>RO / Customer</th>
          <th>Vehicle</th>
          <th>Status / Stage</th>
          <th>Hours</th>
          <th>Sale</th>
          <th>Profit</th>
          <th>Promised</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (!jobs.length) { %>
          <tr>
            <td colspan="8" class="muted">No jobs found.</td>
          </tr>
        <% } %>

        <% jobs.forEach(job => { 
          const labourSale = Number(job.estimatedHours || 0) * Number(job.labourRate || 0);
          const sale = Number(job.estimatedSale || 0) || labourSale + Number(job.partsCost || 0);
          const grossProfit = sale - Number(job.partsCost || 0) - Number(job.otherCost || 0);
        %>
          <tr class="<%= isOverdue(job) ? 'row-overdue' : (isDueSoon(job) ? 'row-due-soon' : '') %>">
            <td>
              <strong><%= job.roNumber %></strong><br>
              <span class="muted"><%= job.customerName %></span>
            </td>
            <td><%= [job.year, job.make, job.model].filter(Boolean).join(" ") || "—" %></td>
            <td>
              <span class="status-pill status-<%= job.status %>"><%= statusLabel(job.status) %></span><br>
              <span class="muted"><%= job.stage || "—" %></span>
            </td>
            <td>
              <%= Number(job.hoursWorked || 0).toFixed(1) %> /
              <%= Number(job.estimatedHours || 0).toFixed(1) %>
            </td>
            <td>$<%= sale.toFixed(0) %></td>
            <td>$<%= grossProfit.toFixed(0) %></td>
            <td>
              <% if (job.promisedDate) { %>
                <%= new Date(job.promisedDate).toLocaleDateString() %>
                <% if (isOverdue(job)) { %><br><span class="warn-text">Overdue</span><% } %>
                <% if (!isOverdue(job) && isDueSoon(job)) { %><br><span class="soon-text">Due soon</span><% } %>
              <% } else { %>
                —
              <% } %>
            </td>
            <td>
              <div class="mobile-stack">
                <a href="/jobs/<%= job.id %>" class="button secondary small">Open</a>
                <a href="/jobs/<%= job.id %>/print" class="button secondary small" target="_blank">Print</a>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
