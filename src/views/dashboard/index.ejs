<section class="stats-grid">
  <div class="stat-card">
    <div class="stat-label">Jobs</div>
    <div class="stat-value"><%= stats.totalJobs %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Open Jobs</div>
    <div class="stat-value"><%= stats.openJobs %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Waiting Parts</div>
    <div class="stat-value"><%= stats.waitingParts %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Ready To Deliver</div>
    <div class="stat-value"><%= stats.readyToDeliver %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Clocked In</div>
    <div class="stat-value"><%= stats.clockedIn %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Gross Profit</div>
    <div class="stat-value">$<%= stats.grossProfit.toFixed(0) %></div>
  </div>
</section>

<section class="card">
  <div class="section-head">
    <h1>Dashboard</h1>
    <div class="mobile-stack">
      <a href="/jobs/new" class="button">New Job</a>
      <a href="/timeclock" class="button secondary">Time Clock</a>
      <a href="/production" class="button secondary">Production Board</a>
      <a href="/reports" class="button secondary">KPI Reports</a>
    </div>
  </div>

  <form method="get" action="/dashboard" class="form-grid" style="margin-bottom:16px;">
    <div>
      <label>Status Filter</label>
      <select name="status">
        <option value="">All</option>
        <% statusOptions.forEach(option => { %>
          <option value="<%= option.value %>" <%= filterStatus === option.value ? "selected" : "" %>>
            <%= option.label %>
          </option>
        <% }) %>
      </select>
    </div>

    <div>
      <label>Search</label>
      <input name="q" value="<%= q || '' %>" placeholder="RO, customer, make, model, VIN, plate" />
    </div>

    <div style="display:flex;align-items:flex-end;">
      <button class="button">Apply Filters</button>
    </div>
  </form>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>RO</th>
          <th>Customer</th>
          <th>Status</th>
          <th>Technician</th>
          <th>Hours</th>
          <th>Promised</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (!jobs.length) { %>
          <tr>
            <td colspan="7" class="muted">No jobs found.</td>
          </tr>
        <% } %>

        <% jobs.forEach(job => { %>
          <tr class="<%= isOverdue(job) ? 'row-overdue' : (isDueSoon(job) ? 'row-due-soon' : '') %>">
            <td>
              <strong><%= job.roNumber %></strong><br>
              <span class="muted"><%= job.customerName %></span>
            </td>
            <td>
              <%= [job.year, job.make, job.model].filter(Boolean).join(" ") || "—" %>
            </td>
            <td>
              <span class="status-pill status-<%= job.status %>"><%= statusLabel(job.status) %></span><br>
              <span class="muted"><%= job.stage || "—" %></span>
            </td>
            <td><%= job.technician || "Unassigned" %></td>
            <td>
              <%= Number(job.hoursWorked || 0).toFixed(1) %> /
              <%= Number(job.estimatedHours || 0).toFixed(1) %>
            </td>
            <td>
              <% if (job.promisedDate) { %>
                <%= new Date(job.promisedDate).toLocaleDateString() %>
              <% } else { %>—<% } %>
            </td>
            <td>
              <div class="mobile-stack">
                <a href="/jobs/<%= job.id %>" class="button secondary small">Open</a>
                <a href="/jobs/<%= job.id %>/print" class="button secondary small" target="_blank">Print</a>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
