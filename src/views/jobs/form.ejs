<section class="card">
  <div class="section-head">
    <h1><%= job ? `Edit Job ${job.roNumber}` : "New Job" %></h1>
    <div style="display:flex;gap:10px;flex-wrap:wrap;">
      <a href="/dashboard" class="button secondary">Back</a>
      <% if (job) { %>
        <a href="/status/<%= job.customerPortalToken %>" class="button secondary">Customer Page</a>
        <a href="/jobs/<%= job.id %>/print" class="button secondary" target="_blank">Print</a>
      <% } %>
    </div>
  </div>

  <form action="<%= job ? `/jobs/${job.id}` : '/jobs' %>" method="post" class="form-grid">
    <div>
      <label>RO Number</label>
      <input name="roNumber" required value="<%= job?.roNumber || '' %>" />
    </div>

    <div>
      <label>Status</label>
      <select name="status">
        <% statusOptions.forEach(option => { %>
          <option value="<%= option.value %>" <%= (job?.status || "ON_LOT") === option.value ? "selected" : "" %>>
            <%= option.label %>
          </option>
        <% }) %>
      </select>
    </div>

    <div>
      <label>Customer Name</label>
      <input name="customerName" required value="<%= job?.customerName || '' %>" />
    </div>

    <div>
      <label>Customer Phone</label>
      <input name="customerPhone" value="<%= job?.customerPhone || '' %>" />
    </div>

    <div>
      <label>Customer Email</label>
      <input type="email" name="customerEmail" value="<%= job?.customerEmail || '' %>" />
    </div>

    <div>
      <label>Advisor</label>
      <input name="advisor" value="<%= job?.advisor || '' %>" />
    </div>

    <div>
      <label>Year</label>
      <input name="year" value="<%= job?.year || '' %>" />
    </div>

    <div>
      <label>Make</label>
      <input name="make" value="<%= job?.make || '' %>" />
    </div>

    <div>
      <label>Model</label>
      <input name="model" value="<%= job?.model || '' %>" />
    </div>

    <div>
      <label>Color</label>
      <input name="color" value="<%= job?.color || '' %>" />
    </div>

    <div>
      <label>VIN</label>
      <input name="vin" value="<%= job?.vin || '' %>" />
    </div>

    <div>
      <label>Plate</label>
      <input name="plate" value="<%= job?.plate || '' %>" />
    </div>

    <div>
      <label>Insurance Provider</label>
      <input name="insuranceProvider" value="<%= job?.insuranceProvider || '' %>" />
    </div>

    <div>
      <label>Claim Number</label>
      <input name="claimNumber" value="<%= job?.claimNumber || '' %>" />
    </div>

    <div>
      <label>Technician</label>
      <input name="technician" value="<%= job?.technician || '' %>" />
    </div>

    <div>
      <label>Stage</label>
      <input name="stage" value="<%= job?.stage || '' %>" />
    </div>

    <div>
      <label>Date In</label>
      <input type="date" name="dateIn" value="<%= job ? formatDateInput(job.dateIn) : '' %>" />
    </div>

    <div>
      <label>Promised Date</label>
      <input type="date" name="promisedDate" value="<%= job ? formatDateInput(job.promisedDate) : '' %>" />
    </div>

    <div>
      <label>Estimated Hours</label>
      <input type="number" step="0.1" min="0" name="estimatedHours" value="<%= job?.estimatedHours ?? 0 %>" />
    </div>

    <div>
      <label>Hours Worked</label>
      <input type="number" step="0.1" min="0" name="hoursWorked" value="<%= job?.hoursWorked ?? 0 %>" />
    </div>

    <div>
      <label>Labour Rate</label>
      <input type="number" step="0.01" min="0" name="labourRate" value="<%= job?.labourRate ?? 0 %>" />
    </div>

    <div>
      <label>Parts Cost</label>
      <input type="number" step="0.01" min="0" name="partsCost" value="<%= job?.partsCost ?? 0 %>" />
    </div>

    <div>
      <label>Other Cost</label>
      <input type="number" step="0.01" min="0" name="otherCost" value="<%= job?.otherCost ?? 0 %>" />
    </div>

    <div>
      <label>Estimated Sale</label>
      <input type="number" step="0.01" min="0" name="estimatedSale" value="<%= job?.estimatedSale ?? 0 %>" />
    </div>

    <div>
      <label>Parts ETA</label>
      <input type="date" name="partsEta" value="<%= job ? formatDateInput(job.partsEta) : '' %>" />
    </div>

    <div>
      <label>Rental Needed</label>
      <select name="rentalNeeded">
        <option value="false" <%= !job?.rentalNeeded ? "selected" : "" %>>No</option>
        <option value="true" <%= job?.rentalNeeded ? "selected" : "" %>>Yes</option>
      </select>
    </div>

    <div class="full">
      <label>Parts Ordered / Needed</label>
      <textarea name="partsOrdered"><%= job?.partsOrdered || '' %></textarea>
    </div>

    <div class="full">
      <label>Required Items / Approvals</label>
      <textarea name="requiredItems"><%= job?.requiredItems || '' %></textarea>
    </div>

    <div class="full">
      <label>Repair Notes</label>
      <textarea name="notes"><%= job?.notes || '' %></textarea>
    </div>

    <div class="full">
      <label>QC Notes</label>
      <textarea name="qcNotes"><%= job?.qcNotes || '' %></textarea>
    </div>

    <div class="full">
      <button class="button"><%= job ? "Save Changes" : "Create Job" %></button>
    </div>
  </form>

  <% if (job) { 
    const labourSale = Number(job.estimatedHours || 0) * Number(job.labourRate || 0);
    const sale = Number(job.estimatedSale || 0) || labourSale + Number(job.partsCost || 0);
    const grossProfit = sale - Number(job.partsCost || 0) - Number(job.otherCost || 0);
  %>
    <section class="stats-grid" style="margin-top:20px;">
      <div class="stat-card">
        <div class="stat-label">Labour Potential</div>
        <div class="stat-value">$<%= labourSale.toFixed(0) %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Estimated Sale</div>
        <div class="stat-value">$<%= sale.toFixed(0) %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Gross Profit</div>
        <div class="stat-value">$<%= grossProfit.toFixed(0) %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Hours Left</div>
        <div class="stat-value"><%= hoursLeft(job).toFixed(1) %></div>
      </div>
    </section>
  <% } %>

  <% if (job) { %>
    <hr style="margin:24px 0;border:none;border-top:1px solid #e2e8f0;">
    <div class="section-head"><h2>Photos</h2></div>

    <form action="/jobs/<%= job.id %>/photos" method="post" enctype="multipart/form-data" class="form-grid">
      <div>
        <label>Select Photo</label>
        <input type="file" name="photo" accept="image/*" required />
      </div>
      <div>
        <label>Caption</label>
        <input name="caption" />
      </div>
      <div class="full">
        <button class="button">Upload Photo</button>
      </div>
    </form>

    <% if (photos && photos.length) { %>
      <div class="photo-grid">
        <% photos.forEach(photo => { %>
          <div class="photo-card">
            <img src="<%= photo.filePath %>" alt="Job photo" class="job-photo" />
            <div class="muted" style="margin-top:8px;"><%= photo.caption || "No caption" %></div>
            <form action="/photos/<%= photo.id %>/delete" method="post" style="margin-top:10px;">
              <input type="hidden" name="jobId" value="<%= job.id %>" />
              <button class="button secondary small">Delete Photo</button>
            </form>
          </div>
        <% }) %>
      </div>
    <% } %>

    <hr style="margin:24px 0;border:none;border-top:1px solid #e2e8f0;">
    <div class="section-head"><h2>Parts</h2></div>

    <form action="/jobs/<%= job.id %>/parts" method="post" class="form-grid">
      <div><label>Part Name</label><input name="name" required /></div>
      <div><label>Vendor</label><input name="vendor" /></div>
      <div><label>Quantity</label><input type="number" min="1" name="quantity" value="1" /></div>
      <div><label>ETA</label><input type="date" name="eta" /></div>
      <div>
        <label>Status</label>
        <select name="status">
          <option value="ORDERED">Ordered</option>
          <option value="RECEIVED">Received</option>
          <option value="BACKORDERED">Backordered</option>
          <option value="CANCELLED">Cancelled</option>
        </select>
      </div>
      <div><label>Notes</label><input name="notes" /></div>
      <div class="full"><button class="button">Add Part</button></div>
    </form>

    <% if (parts && parts.length) { %>
      <div class="table-wrap" style="margin-top:16px;">
        <table>
          <thead>
            <tr>
              <th>Part</th><th>Vendor</th><th>Qty</th><th>Status</th><th>ETA</th><th>Notes</th><th>Update</th>
            </tr>
          </thead>
          <tbody>
            <% parts.forEach(part => { %>
              <tr>
                <td><%= part.name %></td>
                <td><%= part.vendor || "—" %></td>
                <td><%= part.quantity %></td>
                <td><%= part.status %></td>
                <td><%= part.eta ? new Date(part.eta).toLocaleDateString() : "—" %></td>
                <td><%= part.notes || "—" %></td>
                <td>
                  <form action="/parts/<%= part.id %>/status" method="post" style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                    <input type="hidden" name="jobId" value="<%= job.id %>" />
                    <select name="status">
                      <option value="ORDERED" <%= part.status === "ORDERED" ? "selected" : "" %>>Ordered</option>
                      <option value="RECEIVED" <%= part.status === "RECEIVED" ? "selected" : "" %>>Received</option>
                      <option value="BACKORDERED" <%= part.status === "BACKORDERED" ? "selected" : "" %>>Backordered</option>
                      <option value="CANCELLED" <%= part.status === "CANCELLED" ? "selected" : "" %>>Cancelled</option>
                    </select>
                    <button class="button secondary small">Save</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

    <hr style="margin:24px 0;border:none;border-top:1px solid #e2e8f0;">
    <h2>Post Internal or Customer Update</h2>

    <form action="/jobs/<%= job.id %>/updates" method="post" class="form-grid">
      <div class="full">
        <label>Update Message</label>
        <textarea name="message" required></textarea>
      </div>
      <div>
        <label>Visible to Customer</label>
        <select name="customerVisible">
          <option value="false">No</option>
          <option value="true">Yes</option>
        </select>
      </div>
      <div style="display:flex;align-items:flex-end;">
        <button class="button">Add Update</button>
      </div>
    </form>

    <% if (updates && updates.length) { %>
      <div style="margin-top:20px;">
        <h2>Job Updates</h2>
        <% updates.forEach(update => { %>
          <div class="card" style="margin-top:12px;">
            <div><strong><%= update.message %></strong></div>
            <div class="muted" style="margin-top:6px;">
              <%= update.customerVisible ? "Customer Visible" : "Internal Only" %> ·
              <%= new Date(update.createdAt).toLocaleString() %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <hr style="margin:24px 0;border:none;border-top:1px solid #e2e8f0;">
    <div class="section-head"><h2>Workflow</h2></div>
    <form action="/jobs/<%= job.id %>/deliver" method="post">
      <button class="button secondary">Mark Delivered</button>
    </form>
  <% } %>
</section>
