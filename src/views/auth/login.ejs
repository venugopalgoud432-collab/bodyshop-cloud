<div class="auth-wrap">
  <div class="card auth-card">
    <h1>Staff Login</h1>
    <p class="muted">Log in to access jobs, production status, parts, and shop workflow.</p>

    <form action="/login" method="post" class="form-grid single">
      <div>
        <label>Email</label>
        <input type="email" name="email" required />
      </div>

      <div>
        <label>Password</label>
        <input type="password" name="password" required />
      </div>

      <button class="button">Log In</button>
    </form>
  </div>
</div>
